PORT=4000
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/noticrack
# Opcional: contenido del CA cert para verificacion SSL completa en produccion
# DB_SSL_CERT=

# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND

CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Solo necesarias para correr: npm run db:init
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_PERIODISTA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
